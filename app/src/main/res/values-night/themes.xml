<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark-mode overrides – rose/lavender palette (matches light theme hue) -->
    <style name="Base.Theme.MyTrip" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary: lighter rose for dark mode -->
        <item name="colorPrimary">#E8B4BC</item>
        <item name="colorOnPrimary">#4A1520</item>
        <item name="colorPrimaryContainer">#6B3040</item>
        <item name="colorOnPrimaryContainer">#FFD9DB</item>
        <!-- Secondary: lighter lavender -->
        <item name="colorSecondary">#C9C9D4</item>
        <item name="colorOnSecondary">#303040</item>
        <item name="colorSecondaryContainer">#484855</item>
        <item name="colorOnSecondaryContainer">#E5E5F2</item>
        <!-- Tertiary: lighter mocha -->
        <item name="colorTertiary">#D4BFB0</item>
        <item name="colorOnTertiary">#3A2510</item>
        <item name="colorTertiaryContainer">#553C28</item>
        <item name="colorOnTertiaryContainer">#EADACF</item>
        <!-- Background / Surface: dark with rose tint -->
        <item name="android:colorBackground">#1A1318</item>
        <item name="colorSurface">#1A1318</item>
        <item name="colorOnSurface">#EDE0E2</item>
        <item name="colorSurfaceVariant">#4A3840</item>
        <item name="colorOnSurfaceVariant">#CCBDC0</item>
        <!-- Error -->
        <item name="colorError">#FFB4AB</item>
        <item name="colorOnError">#690005</item>

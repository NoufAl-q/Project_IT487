<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark-mode overrides – dusty rose / lavender / mint palette -->
    <style name="Base.Theme.MyTrip" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary: lighter dusty rose for dark bg -->
        <item name="colorPrimary">#E8B4B4</item>
        <item name="colorOnPrimary">#4A1820</item>
        <item name="colorPrimaryContainer">#6B3035</item>
        <item name="colorOnPrimaryContainer">#FFD9D9</item>
        <!-- Secondary: lighter lavender -->
        <item name="colorSecondary">#C8B8D8</item>
        <item name="colorOnSecondary">#2A1E3D</item>
        <item name="colorSecondaryContainer">#483858</item>
        <item name="colorOnSecondaryContainer">#EBE5F5</item>
        <!-- Tertiary: lighter mint -->
        <item name="colorTertiary">#A8D0CC</item>
        <item name="colorOnTertiary">#0E3230</item>
        <item name="colorTertiaryContainer">#1E4845</item>
        <item name="colorOnTertiaryContainer">#D8EFED</item>
        <!-- Background / Surface: dark with rose tint -->
        <item name="android:colorBackground">#1C1418</item>
        <item name="colorSurface">#1C1418</item>
        <item name="colorOnSurface">#EDE0E0</item>
        <item name="colorSurfaceVariant">#4A3838</item>
        <item name="colorOnSurfaceVariant">#CCBCBC</item>
        <!-- Error -->
        <item name="colorError">#FFB4AB</item>
